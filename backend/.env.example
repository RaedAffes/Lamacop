# LamaCop Backend Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git (it contains passwords!)

# Database Configuration
DB_HOST=raed-mysql.mysql.database.azure.com
DB_USER=raed
DB_PASSWORD=your_azure_mysql_password
DB_PORT=3306
DB_NAME=lamacop

# FastAPI Configuration
DEBUG=True
API_PREFIX=/api/v1

# CORS Configuration
FRONTEND_URL=http://localhost

# Azure Blob Storage Configuration
# If you don't use a connection string, provide account name + account key.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=raedstoraccount
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=raed-blob
